#!/usr/bin/env python3
"""
Called after a BDM scheduled task completes.
Updates ~/.claude/bdm-task-state.json with lastRunAt timestamp.
Usage: hmz-bdm-state-update <task_id>
"""
import json
import os
import sys
from datetime import datetime, timezone

STATE_FILE = os.path.expanduser("~/.claude/bdm-task-state.json")

task_id = sys.argv[1] if len(sys.argv) > 1 else None
if not task_id:
    sys.exit(0)

state = {}
if os.path.exists(STATE_FILE):
    try:
        with open(STATE_FILE) as f:
            state = json.load(f)
    except Exception:
        state = {}

state[task_id] = {"lastRunAt": datetime.now(timezone.utc).isoformat()}

with open(STATE_FILE, "w") as f:
    json.dump(state, f, indent=2)
