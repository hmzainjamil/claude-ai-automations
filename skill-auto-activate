#!/usr/bin/env bash
# Dispatch Router — UserPromptSubmit hook.
# 1. Reset to core  2. Keyword-match prompt  3. Activate minimum skill set  4. Log metrics

set -e
SKILLS_BIN="$HOME/.claude/bin"
ACTIVE="$HOME/.claude/skills"
ARCHIVE="$HOME/.claude/skills-archive"
METRICS="$HOME/.claude/metrics.log"

# ── Step 1: Reset to core ────────────────────────────────────────
"$SKILLS_BIN/skill-reset" > /dev/null 2>&1

# ── Step 2: Extract prompt ───────────────────────────────────────
PROMPT=$(python3 -c "
import json,sys
try:
    d=json.load(sys.stdin); print(d.get('prompt','').lower())
except: pass
" 2>/dev/null || echo "")
[ -z "$PROMPT" ] && exit 0

TS=$(date +%s)
ACTIVATED=()

# ── Step 3: Dispatch functions ───────────────────────────────────
on() {
  local skill="$1"
  [ -e "$ACTIVE/$skill" ] && return 0
  [ -e "$ARCHIVE/$skill" ] && mv "$ARCHIVE/$skill" "$ACTIVE/$skill" 2>/dev/null && ACTIVATED+=("$skill")
}
match() { echo "$PROMPT" | grep -qiE "$1"; }

